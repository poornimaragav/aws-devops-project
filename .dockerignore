```dockerignore
# Git
.git
.gitignore
.github/

# Terraform
terraform/
.terraform/
*.tfstate
*.tfstate.*
*.tfvars

# Documentation
README.md
LICENSE
docs/

# IDE files
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Environment files
.env
.env.*

# Node.js
node_modules/
npm-debug.log*

# Docker
docker-compose.yml
docker-compose.override.yml

# AWS credentials
.aws/
*.pem
*.key

# Temporary files
tmp/
temp/
```
